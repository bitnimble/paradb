{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(echo \"exit=$?\")",
      "Bash(echo \"outer exit=$?\")",
      "Bash(echo \"EXIT=$?\")",
      "Bash(bun install)",
      "Bash(mcp__plugin_playwright_playwright_browser_navigate)",
      "Bash(mcp__plugin_playwright_playwright_browser_take_screenshot)",
      "Bash(mcp__plugin_playwright_playwright_browser_click)",
      "Bash(mcp__plugin_playwright_playwright_browser_evaluate)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git grep *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git rebase *)",
      "Bash(git status *)",
      "Bash(bun run build *)",
      "Bash(bun typecheck *)",
      "Bash(bun run typecheck *)",
      "Bash(bun run typecheck:e2e *)",
      "Bash(bun lint *)",
      "Bash(bun run lint *)",
      "Bash(bun format *)",
      "Bash(bun run format *)",
      "Bash(bun add *)",
      "Bash(bun test *)",
      "Bash(bun run test *)",
      "Bash(bun run test:unit *)",
      "Bash(bun test:integration *)",
      "Bash(bun run test:integration *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git show *)"
    ],
    "deny": ["Write(supabase/migrations/*)"],
    "defaultMode": "acceptEdits"
  }
}
