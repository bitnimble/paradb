{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bunx tsc:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(bun add:*)",
      "Bash(bunx playwright test:*)",
      "Bash(bun run:*)",
      "Bash(bun eslint:*)",
      "Bash(bun tsc:*)",
      "Bash(bun test:*)",
      "Bash(bun format:*)",
      "Skill(claude-api)",
      "Skill(claude-api:*)"
    ],
    "deny": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node -e:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(bunx prettier:*)",
      "Bash(bun prettier:*)",
      "Bash(bun eslint:*)"
    ],
    "defaultMode": "acceptEdits"
  }
}
