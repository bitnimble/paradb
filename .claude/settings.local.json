{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",

      "Bash(mcp__plugin_playwright_playwright_browser_navigate)",
      "Bash(mcp__plugin_playwright_playwright_browser_take_screenshot)",
      "Bash(mcp__plugin_playwright_playwright_browser_click)",
      "Bash(mcp__plugin_playwright_playwright_browser_evaluate)",

      "Bash(bun install)",
      "Bash(bun run build *)",
      "Bash(bun typecheck *)",
      "Bash(bun run typecheck *)",
      "Bash(bun run typecheck:e2e *)",
      "Bash(bun lint *)",
      "Bash(bun run lint *)",
      "Bash(bun format *)",
      "Bash(bun run format *)",
      "Bash(bun add *)",
      "Bash(bun test *)",
      "Bash(bun run test *)",
      "Bash(bun run test:unit *)",
      "Bash(bun test:integration *)",
      "Bash(bun run test:integration *)",

      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git commit *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git reset *)",

      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(diff *)",
      "Bash(cmp *)",
      "Bash(ls *)",
      "Bash(stat *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd *)"
    ],
    "deny": [
      "Bash(supabase db reset)",
      "Bash(supabase db push)",
      "Bash(supabase start)",
      "Bash(supabase db start)",
      "Bash(supabase db diff)",
      "Bash(git push *)",
      "Write(supabase/migrations/*)"
    ],
    "defaultMode": "acceptEdits"
  }
}
